{
  "name": "@instalock/scripts",
  "author": "Tahmid Ahmed",
  "version": "1.0.40",
  "description": "Do not install these into the other packages - Scripts to pull certain data about Valorant required for core functionality of Instalock.",
  "main": "index.ts",
  "scripts": {
    "build": "esbuild cron/index.ts --bundle --platform=node --outfile=cron/index.cjs",
    "start": "NODE_ENV=production node cron/index.cjs",
    "dev": "NODE_ENV=development dotenvx run -f ../../.env -- pnpx tsx cron/index.ts --watch",
    "test": "pnpm run typecheck && pnpm run fmt && pnpm run lint",
    "typecheck": "tsc -b --noEmit",
    "fmt": "pnpm run prettier",
    "fmt:fix": "pnpm run prettier:fix",
    "lint": "pnpm run eslint",
    "lint:fix": "pnpm run eslint:fix",
    "eslint": "eslint .",
    "eslint:fix": "eslint . --fix",
    "prettier": "NODE_OPTIONS=\"--experimental-strip-types\" prettier --check .",
    "prettier:fix": "NODE_OPTIONS=\"--experimental-strip-types\" prettier --write ."
  },
  "keywords": [],
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-perfectionist": "catalog:",
    "eslint-plugin-react": "catalog:",
    "eslint-plugin-react-hooks": "catalog:",
    "eslint-plugin-react-refresh": "catalog:",
    "globals": "catalog:",
    "pino-pretty": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:"
  },
  "dependencies": {
    "@instalock/db": "workspace:^",
    "@instalock/log": "workspace:^",
    "@instalock/meter": "workspace:^",
    "@instalock/riot": "workspace:^",
    "esbuild": "catalog:",
    "pino": "catalog:",
    "postgres": "catalog:",
    "prom-client": "catalog:",
    "sharp": "catalog:"
  }
}
