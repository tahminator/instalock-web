{
  "name": "@instalock/frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "pnpm run typecheck && pnpm run fmt && pnpm run lint && pnpm run build",
    "typecheck": "tsc -b --noEmit",
    "fmt": "pnpm run prettier",
    "fmt:fix": "pnpm run prettier:fix",
    "lint": "pnpm run eslint",
    "lint:fix": "pnpm run eslint:fix",
    "eslint": "eslint .",
    "eslint:fix": "eslint . --fix",
    "prettier": "prettier --check .",
    "prettier:fix": "prettier --write ."
  },
  "dependencies": {
    "@instalock/fetcher": "workspace:^",
    "@instalock/ui": "workspace:^",
    "react": "catalog:react18",
    "react-dom": "catalog:react18",
    "superjson": "catalog:superjson",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "postcss": "^8.4.49",
    "vite": "^6.0.5",
    "vite-tsconfig-paths": "^5.1.4",
    "@eslint/js": "^9.15.0",
    "eslint": "^9.39.2",
    "eslint-plugin-perfectionist": "^5.1.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.15.0",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.15.0",
    "prettier": "^3.8.1"
  }
}
