{
  "name": "@instalock/frontend",
  "author": "Tahmid Ahmed",
  "version": "1.0.36",
  "description": "Instalock main web UI",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "pnpm run typecheck && pnpm run fmt && pnpm run lint && pnpm run build",
    "typecheck": "tsc -b --noEmit",
    "fmt": "pnpm run prettier",
    "fmt:fix": "pnpm run prettier:fix",
    "lint": "pnpm run eslint",
    "lint:fix": "pnpm run eslint:fix",
    "eslint": "eslint .",
    "eslint:fix": "eslint . --fix",
    "prettier": "NODE_OPTIONS=\"--experimental-strip-types\" prettier --check .",
    "prettier:fix": "NODE_OPTIONS=\"--experimental-strip-types\" prettier --write ."
  },
  "dependencies": {
    "@instalock/fetcher": "workspace:^",
    "@instalock/ui": "workspace:^",
    "react": "catalog:",
    "react-dom": "catalog:",
    "superjson": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "postcss": "catalog:",
    "vite": "catalog:",
    "vite-tsconfig-paths": "catalog:",
    "@eslint/js": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-perfectionist": "catalog:",
    "eslint-plugin-react": "catalog:",
    "eslint-plugin-react-hooks": "catalog:",
    "eslint-plugin-react-refresh": "catalog:",
    "globals": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "prettier": "catalog:"
  }
}
