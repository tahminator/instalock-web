{
  "name": "@instalock/server",
  "version": "1.0.0",
  "description": "Server Entrypoint for Instalock",
  "main": "index.ts",
  "scripts": {
    "dev": "NODE_ENV=development dotenvx run -f ../../.env -- tsx --watch src/index.ts",
    "test": "pnpm run typecheck && pnpm run fmt && pnpm run lint",
    "typecheck": "tsc -b --noEmit",
    "fmt": "pnpm run prettier",
    "fmt:fix": "pnpm run prettier:fix",
    "lint": "pnpm run eslint",
    "lint:fix": "pnpm run eslint:fix",
    "eslint": "eslint .",
    "eslint:fix": "eslint . --fix",
    "prettier": "prettier --check .",
    "prettier:fix": "prettier --write .",
    "build": "esbuild src/index.ts --bundle --platform=node --outfile=src/index.js",
    "start": "NODE_ENV=production node src/index.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@instalock/api": "workspace:^",
    "@instalock/attempt": "workspace:^",
    "@instalock/db": "workspace:^",
    "@instalock/riot": "workspace:^",
    "@tahminator/sapling": "catalog:sapling",
    "arctic": "^2.3.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "esbuild": "^0.25.0",
    "express": "catalog:express5",
    "express-prom-bundle": "^8.0.0",
    "express-rate-limit": "^7.5.0",
    "ioredis": "^5.4.2",
    "lucia": "^3.2.2",
    "morgan": "^1.10.0",
    "oslo": "^1.2.1",
    "pino": "^10.3.1",
    "postgres": "^3.4.7",
    "prom-client": "^15.1.3",
    "rate-limit-redis": "^4.2.0",
    "superjson": "catalog:superjson",
    "tsx": "^4.19.2",
    "zod": "^4.2.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.9",
    "pino-pretty": "^13.1.3",
    "@eslint/js": "^9.15.0",
    "eslint": "^9.39.2",
    "eslint-plugin-perfectionist": "^5.1.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.15.0",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.15.0",
    "prettier": "^3.8.1"
  }
}
