{
  "name": "@instalock/server",
  "author": "Tahmid Ahmed",
  "version": "1.0.13",
  "description": "Server Entrypoint for Instalock",
  "main": "index.ts",
  "scripts": {
    "dev": "NODE_ENV=development dotenvx run -f ../../.env -- tsx --watch src/index.ts",
    "test": "pnpm run typecheck && pnpm run fmt && pnpm run lint",
    "typecheck": "tsc -b --noEmit",
    "fmt": "pnpm run prettier",
    "fmt:fix": "pnpm run prettier:fix",
    "lint": "pnpm run eslint",
    "lint:fix": "pnpm run eslint:fix",
    "eslint": "eslint .",
    "eslint:fix": "eslint . --fix",
    "prettier": "NODE_OPTIONS=\"--experimental-strip-types\" prettier --check .",
    "prettier:fix": "NODE_OPTIONS=\"--experimental-strip-types\" prettier --write .",
    "build": "esbuild src/index.ts --bundle --platform=node --outfile=src/index.js",
    "start": "NODE_ENV=production node src/index.js"
  },
  "keywords": [],
  "license": "ISC",
  "dependencies": {
    "@instalock/api": "workspace:^",
    "@instalock/attempt": "workspace:^",
    "@instalock/db": "workspace:^",
    "@instalock/riot": "workspace:^",
    "@tahminator/sapling": "catalog:",
    "arctic": "catalog:",
    "cookie-parser": "catalog:",
    "cors": "catalog:",
    "esbuild": "catalog:",
    "express": "catalog:",
    "express-prom-bundle": "catalog:",
    "express-rate-limit": "catalog:",
    "ioredis": "catalog:",
    "lucia": "catalog:",
    "morgan": "catalog:",
    "oslo": "catalog:",
    "pino": "catalog:",
    "postgres": "catalog:",
    "prom-client": "catalog:",
    "rate-limit-redis": "catalog:",
    "superjson": "catalog:",
    "tsx": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/cookie-parser": "catalog:",
    "@types/cors": "catalog:",
    "@types/express": "catalog:",
    "@types/morgan": "catalog:",
    "pino-pretty": "catalog:",
    "@eslint/js": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-perfectionist": "catalog:",
    "eslint-plugin-react": "catalog:",
    "eslint-plugin-react-hooks": "catalog:",
    "eslint-plugin-react-refresh": "catalog:",
    "globals": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "prettier": "catalog:"
  }
}
