{
  "name": "@instalock/server",
  "author": "Tahmid Ahmed",
  "version": "1.0.40",
  "description": "Server Entrypoint for Instalock",
  "main": "index.ts",
  "scripts": {
    "dev": "concurrently -k \"pnpm run build:watch\" \"pnpm run start:dev:watch\"",
    "devd": "concurrently -k \"pnpm run build:watch\" \"pnpm run start:devd:watch\"",
    "test": "pnpm run typecheck && pnpm run fmt && pnpm run lint",
    "typecheck": "tsc -b --noEmit",
    "fmt": "pnpm run prettier",
    "fmt:fix": "pnpm run prettier:fix",
    "lint": "pnpm run eslint",
    "lint:fix": "pnpm run eslint:fix",
    "eslint": "eslint .",
    "eslint:fix": "eslint . --fix",
    "prettier": "NODE_OPTIONS=\"--experimental-strip-types\" prettier --check .",
    "prettier:fix": "NODE_OPTIONS=\"--experimental-strip-types\" prettier --write .",
    "build": "tsx build.ts",
    "build:watch": "nodemon --delay 200ms --watch src --ext ts --ignore src/index.js  --exec \"tsx build.ts\"",
    "start": "NODE_ENV=production NODE_OPTIONS=--enable-source-maps node src/index.js",
    "start:dev": "NODE_ENV=development NODE_OPTIONS=--enable-source-maps dotenvx run -f ../../.env -- node src/index.js",
    "start:devd": "NODE_ENV=development NODE_OPTIONS=--enable-source-maps dotenvx run -f ../../.env -- node --inspect src/index.js",
    "start:dev:watch": "wait-on src/index.js && nodemon --delay 200ms --watch src/index.js --exec \"pnpm run start:dev\"",
    "start:devd:watch": "wait-on src/index.js && nodemon --delay 200ms --watch src/index.js --exec \"pnpm run start:devd\""
  },
  "keywords": [],
  "license": "ISC",
  "dependencies": {
    "@instalock/api": "workspace:^",
    "@instalock/attempt": "workspace:^",
    "@instalock/db": "workspace:^",
    "@instalock/log": "workspace:^",
    "@instalock/meter": "workspace:^",
    "@instalock/riot": "workspace:^",
    "@tahminator/sapling": "catalog:",
    "arctic": "catalog:",
    "cookie-parser": "catalog:",
    "cors": "catalog:",
    "express": "catalog:",
    "express-prom-bundle": "catalog:",
    "express-rate-limit": "catalog:",
    "ioredis": "catalog:",
    "lucia": "catalog:",
    "morgan": "catalog:",
    "oslo": "catalog:",
    "postgres": "catalog:",
    "prom-client": "catalog:",
    "rate-limit-redis": "catalog:",
    "superjson": "catalog:",
    "tsx": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@types/cookie-parser": "catalog:",
    "@types/cors": "catalog:",
    "@types/express": "catalog:",
    "@types/morgan": "catalog:",
    "@types/node": "catalog:",
    "esbuild": "catalog:",
    "esbuild-plugin-import-pattern": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-perfectionist": "catalog:",
    "eslint-plugin-react": "catalog:",
    "eslint-plugin-react-hooks": "catalog:",
    "eslint-plugin-react-refresh": "catalog:",
    "globals": "catalog:",
    "nodemon": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:"
  }
}
