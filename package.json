{
  "name": "instalock",
  "author": "Tahmid Ahmed",
  "version": "1.0.39",
  "description": "Instalock monorepo",
  "engines": {
    "pnpm": "10.5.2"
  },
  "scripts": {
    "generate": "cd scripts/manual && tsx generateMapImages.ts && tsx generateTierImages.ts",
    "frontend:dev": "cd apps/frontend && pnpm run dev",
    "cron:dev": "cd apps/scripts && pnpm run dev",
    "server:dev": "cd apps/server && pnpm run dev",
    "server:devd": "cd apps/server && pnpm run devd",
    "kaboom": "find . -name \"node_modules\" -type d -prune -exec trash '{}' + && find . -name \"tsconfig.tsbuildinfo\" -type f -prune -exec trash '{}' +",
    "test": "pnpm run test:parallel",
    "testi": "pnpm -r run test",
    "test:parallel": "pnpm -r --parallel run test",
    "test:then:fail": "pnpm run testi && exit 1",
    "lint:fix": "pnpm -r --parallel run lint:fix",
    "fmt:fix": "pnpm -r --parallel run fmt:fix",
    "dev": "concurrently \"pnpm run frontend:dev\" \"pnpm run server:dev\" \"pnpm run cron:dev\"",
    "devd": "concurrently \"pnpm run frontend:dev\" \"pnpm run server:devd\" \"pnpm run cron:dev\""
  },
  "keywords": [],
  "license": "ISC",
  "devDependencies": {
    "concurrently": "catalog:",
    "@eslint/js": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-perfectionist": "catalog:",
    "eslint-plugin-react": "catalog:",
    "eslint-plugin-react-hooks": "catalog:",
    "eslint-plugin-react-refresh": "catalog:",
    "globals": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "prettier": "catalog:"
  },
  "packageManager": "pnpm@10.5.2"
}
