{
  "name": "@instalock/ui",
  "author": "Tahmid Ahmed",
  "version": "0.0.0",
  "description": "Shared UI for Instalock.",
  "main": "index.ts",
  "scripts": {
    "test": "pnpm run typecheck && pnpm run fmt && pnpm run lint",
    "typecheck": "tsc -b --noEmit",
    "fmt": "pnpm run prettier",
    "fmt:fix": "pnpm run prettier:fix",
    "lint": "pnpm run eslint",
    "lint:fix": "pnpm run eslint:fix",
    "eslint": "eslint .",
    "eslint:fix": "eslint . --fix",
    "prettier": "NODE_OPTIONS=\"--experimental-strip-types\" prettier --check .",
    "prettier:fix": "NODE_OPTIONS=\"--experimental-strip-types\" prettier --write ."
  },
  "dependencies": {
    "@hookform/resolvers": "catalog:",
    "@instalock/api": "workspace:^",
    "@instalock/fetcher": "workspace:^",
    "@instalock/riot": "workspace:^",
    "@mantine/core": "catalog:",
    "@mantine/hooks": "catalog:",
    "@mantine/notifications": "catalog:",
    "@tabler/icons-react": "catalog:",
    "@tailwindcss/postcss": "catalog:",
    "@tanstack/react-query": "catalog:",
    "@tanstack/react-query-devtools": "catalog:",
    "autoprefixer": "catalog:",
    "clsx": "catalog:",
    "framer-motion": "catalog:",
    "postcss": "catalog:",
    "postcss-preset-mantine": "catalog:",
    "postcss-simple-vars": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-hook-form": "catalog:",
    "react-icons": "catalog:",
    "react-router": "catalog:",
    "react-router-dom": "catalog:",
    "tailwindcss": "catalog:",
    "zod": "catalog:",
    "zustand": "catalog:"
  },
  "peerDependencies": {
    "react": "catalog:",
    "react-dom": "catalog:",
    "vite": "catalog:"
  },
  "devDependencies": {
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@eslint/js": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-perfectionist": "catalog:",
    "eslint-plugin-react": "catalog:",
    "eslint-plugin-react-hooks": "catalog:",
    "eslint-plugin-react-refresh": "catalog:",
    "globals": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "prettier": "catalog:"
  }
}
